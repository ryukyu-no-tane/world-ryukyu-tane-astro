---
interface Props {
  title: string;
  description?: string;
}
const { title, description = '沖縄の現場から見えるリアルを、世界へ届ける' } = Astro.props;
---
<!DOCTYPE html>
<html lang="ja">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1.0" />
  <title>{title} | 琉球のタネ</title>
  <meta name="description" content={description} />
  <link rel="preconnect" href="https://fonts.googleapis.com" />
  <link href="https://fonts.googleapis.com/css2?family=Noto+Sans+JP:wght@400;700&display=swap" rel="stylesheet" />
  <link rel="stylesheet" href="/styles/global.css" />
</head>
<body>
  <header>
    <div class="header-inner">
      <a href="/ja/" class="site-title">
        <span class="logo-main">琉球のタネ</span>
        <span class="logo-sub">Ryukyu no Tane</span>
      </a>
      <nav class="lang-nav">
        <a href="/ja/">JP</a>
        <a href="/en/">EN</a>
      </nav>
    </div>
    <nav class="series-nav">
      <a href="/ja/series-f/">🎙 沖縄の記憶</a>
    </nav>
  </header>

  <!-- 表示設定パネル -->
  <div class="ui-controls" id="uiControls">
    <button class="ui-toggle" id="uiToggle" title="表示設定">⚙️</button>
    <div class="ui-panel" id="uiPanel">
      <p class="ui-label">文字サイズ</p>
      <div class="ui-row">
        <button onclick="changeFontSize(-1)">A-</button>
        <button onclick="changeFontSize(0)">標準</button>
        <button onclick="changeFontSize(1)">A+</button>
      </div>
      <p class="ui-label">カラー</p>
      <div class="ui-row">
        <button onclick="changeTheme('default')" class="theme-btn default">標準</button>
        <button onclick="changeTheme('dark')" class="theme-btn dark">ダーク</button>
        <button onclick="changeTheme('warm')" class="theme-btn warm">温かみ</button>
      </div>
    </div>
  </div>

  <main>
    <slot />
  </main>

  <footer>
    <p>© 2026 琉球のタネ / Ryukyu no Tane</p>
    <p class="site-switch">
      現在：<strong>Astro版（試験中）</strong> ／
      <a href="https://world.ryukyu-tane.com/ja/">Hugo版に切り替える →</a>
    </p>
  </footer>

  <script is:raw>
    var sizes = [14, 16, 18, 20];
    var sizeIdx = parseInt(localStorage.getItem('fontSize') || '1');
    document.body.style.fontSize = sizes[sizeIdx] + 'px';
    document.body.setAttribute('data-theme', localStorage.getItem('theme') || 'default');

    function changeFontSize(dir) {
      if (dir === 0) sizeIdx = 1;
      else sizeIdx = Math.max(0, Math.min(sizes.length - 1, sizeIdx + dir));
      document.body.style.fontSize = sizes[sizeIdx] + 'px';
      localStorage.setItem('fontSize', sizeIdx);
    }

    function changeTheme(theme) {
      document.body.setAttribute('data-theme', theme);
      localStorage.setItem('theme', theme);
    }

    document.getElementById('uiToggle').addEventListener('click', function() {
      document.getElementById('uiPanel').classList.toggle('open');
    });
  </script>
</body>
</html>
